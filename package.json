{
  "name": "cf-tanstack-starter",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "lefthook install",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate:local": "pnpm --filter @repo/web db:migrate:local",
    "db:migrate:remote": "pnpm --filter @repo/web db:migrate:remote",
    "db:seed": "pnpm --filter @repo/db db:seed:generate && pnpm --filter @repo/web db:seed",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "db:snapshot": "pnpm --filter @repo/web db:snapshot",
    "deploy": "pnpm --filter @repo/web deploy",
    "deploy:staging": "pnpm --filter @repo/web deploy:staging",
    "preview": "pnpm --filter @repo/web preview",
    "tail": "pnpm --filter @repo/web tail",
    "cf:secret:list": "pnpm --filter @repo/web cf:secret:list",
    "cf:secret:put": "pnpm --filter @repo/web cf:secret:put"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "lefthook": "^1.13.6",
    "tsx": "^4.21.0",
    "turbo": "2.8.15"
  },
  "packageManager": "pnpm@10.6.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "drizzle-orm": "npm:drizzle-orm@beta"
    }
  }
}
