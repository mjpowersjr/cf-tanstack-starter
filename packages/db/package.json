{
  "name": "@repo/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "drizzle-kit push --config drizzle.config.ts",
    "db:migrate:remote": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "tsx scripts/seed-local.ts && wrangler d1 execute DB --local --file seed.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "npm:drizzle-orm@beta",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "drizzle-kit": "npm:drizzle-kit@beta",
    "tsx": "^4.21.0",
    "vitest": "^3.2.1",
    "wrangler": "4.71.0",
    "@cloudflare/workers-types": "4.20260310.1",
    "typescript": "5.9.3"
  }
}
