{
  "name": "@repo/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "routes:generate": "tsx scripts/generate-routes.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "db:migrate:local": "pnpm --filter @repo/db db:migrate:local",
    "db:migrate:remote": "pnpm --filter @repo/db db:migrate:remote",
    "db:seed": "wrangler d1 execute DB --local --file ../../packages/db/seed.sql",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:staging": "pnpm build && wrangler deploy --env staging",
    "preview": "wrangler dev --remote",
    "tail": "wrangler tail",
    "db:snapshot": "pnpm --filter @repo/db db:snapshot",
    "shadcn:diff": "tsx scripts/shadcn.ts diff",
    "shadcn:update": "tsx scripts/shadcn.ts update",
    "cf:secret:list": "wrangler secret list",
    "cf:secret:put": "wrangler secret put"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "@repo/db": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/observability": "workspace:*",
    "@tanstack/react-router": "1.168.26",
    "@tanstack/react-start": "1.167.52",
    "better-auth": "^1.5.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "npm:drizzle-orm@beta",
    "lucide-react": "0.577.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.34.0",
    "@cloudflare/workers-types": "4.20260430.1",
    "@playwright/test": "^1.50.0",
    "@tanstack/router-generator": "1.166.37",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "4.2.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^3.2.1",
    "wrangler": "4.86.0"
  }
}
