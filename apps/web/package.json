{
  "name": "@repo/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed": "wrangler d1 execute DB --local --file ../../packages/db/seed.sql",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "preview": "wrangler dev --remote",
    "tail": "wrangler tail",
    "db:snapshot": "wrangler d1 export DB --remote --output db-snapshot.sql && wrangler d1 execute DB --local --file db-snapshot.sql",
    "cf:secret:list": "wrangler secret list",
    "cf:secret:put": "wrangler secret put"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "@repo/db": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/observability": "workspace:*",
    "@tanstack/react-router": "1.166.6",
    "@tanstack/react-start": "1.166.6",
    "better-auth": "^1.5.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "npm:drizzle-orm@beta",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.26.1",
    "@cloudflare/workers-types": "4.20260310.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^3.2.1",
    "wrangler": "4.71.0"
  }
}
