# Cloudflare Workers environment variables
# Copy this file to .dev.vars for local development:
#   cp .dev.vars.example .dev.vars
#
# D1, R2, and KV bindings are configured in wrangler.jsonc and
# automatically available in local dev mode — no env vars needed.

# Auth (better-auth) — REQUIRED
# Generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-a-random-secret
BETTER_AUTH_URL=http://localhost:5173

# Registration toggle — set to "false" to disable public signup
# The first user to register always becomes admin regardless of this setting.
SIGNUP_ENABLED=true

# Email (Resend) — OPTIONAL
# Required for password reset emails. Without this, reset links are logged to console.
# Sign up at https://resend.com and create an API key.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com
