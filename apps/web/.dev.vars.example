# Cloudflare Workers environment variables
# Copy this file to .dev.vars for local development
#
# D1 and R2 bindings are configured in wrangler.jsonc and
# automatically available in local dev mode — no env vars needed.
#
# Auth (better-auth)
BETTER_AUTH_SECRET=changeme-generate-a-random-secret
BETTER_AUTH_URL=http://localhost:5173
